# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/multi_vendor_ecom

# JWT
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Shipway (stubbed for now)
SHIPWAY_USERNAME=your-shipway-username
SHIPWAY_API_KEY=your-shipway-api-key
SHIPWAY_BASE_URL=https://shipway.in/api

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Master admin seed credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
